<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".SecondFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- ─────────────────────────────────────────────── -->
        <!-- Encabezado del formulario                       -->
        <!-- ─────────────────────────────────────────────── -->

        <TextView
            android:id="@+id/text_form_header"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/form_header"
            android:textAppearance="?attr/textAppearanceHeadlineSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/text_form_subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/form_subtitle"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant" />

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- ─────────────────────────────────────────────── -->
        <!-- Ejemplo de Scroll Horizontal (Niveles de prioridad) -->
        <!-- ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_prioridad_rapida"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:layout_marginTop="8dp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:scrollbars="horizontal">
            <LinearLayout
                android:id="@+id/layout_prioridades"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingBottom="8dp">
                <Button android:id="@+id/btn_prio_baja" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/prio_baja" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn_prio_media" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/prio_media" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn_prio_alta" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/prio_alta" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn_prio_urgente" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/prio_urgente" android:layout_margin="4dp"/>
                <Button android:id="@+id/btn_prio_critica" style="@style/Widget.Material3.Button.TonalButton" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="@string/prio_critica" android:layout_margin="4dp"/>
            </LinearLayout>
        </HorizontalScrollView>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Campo: Nombre de la tarea                       -->
        <!-- ─────────────────────────────────────────────── -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_nombre"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/hint_nombre"
            app:startIconDrawable="@drawable/ic_tasks"
            app:counterEnabled="true"
            app:counterMaxLength="60"
            app:errorEnabled="true">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_nombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text"
                android:maxLines="1"
                android:scrollHorizontally="true" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Campo: Descripción de la tarea                  -->
        <!-- ─────────────────────────────────────────────── -->

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/input_layout_descripcion"
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="@string/hint_descripcion"
            app:counterEnabled="true"
            app:counterMaxLength="200">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/edit_descripcion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textMultiLine"
                android:gravity="top|start"
                android:minLines="3"
                android:maxLines="5"
                android:scrollbars="vertical"
                android:overScrollMode="always" />

        </com.google.android.material.textfield.TextInputLayout>

        <!-- ─────────────────────────────────────────────── -->
        <!-- CheckBox: Urgencia                              -->
        <!-- ─────────────────────────────────────────────── -->

        <com.google.android.material.checkbox.MaterialCheckBox
            android:id="@+id/check_urgente"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_urgente"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:paddingStart="8dp"
            tools:ignore="RtlSymmetry" />

        <!-- ─────────────────────────────────────────────── -->
        <!-- RadioGroup: Categoría                           -->
        <!-- ─────────────────────────────────────────────── -->

        <TextView
            android:id="@+id/text_label_categoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/label_categoria"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <RadioGroup
            android:id="@+id/radio_group_categoria"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="vertical">

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radio_trabajo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:checked="true"
                android:paddingStart="8dp"
                android:text="@string/categoria_trabajo"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                tools:ignore="RtlSymmetry" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radio_personal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:text="@string/categoria_personal"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                tools:ignore="RtlSymmetry" />

            <com.google.android.material.radiobutton.MaterialRadioButton
                android:id="@+id/radio_estudio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="8dp"
                android:text="@string/categoria_estudio"
                android:textAppearance="?attr/textAppearanceBodyLarge"
                tools:ignore="RtlSymmetry" />

        </RadioGroup>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Ejemplo de ListView (Sugerencias)               -->
        <!-- ─────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_sugerencias"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:layout_marginTop="20dp"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <ListView
            android:id="@+id/list_sugerencias"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:layout_marginTop="8dp"
            android:divider="?attr/colorOutlineVariant"
            android:dividerHeight="1dp"
            android:background="?attr/colorSurfaceContainerLowest"/>

        <!-- ─────────────────────────────────────────────── -->
        <!-- Sección Ubicación GPS y Google Maps             -->
        <!-- ─────────────────────────────────────────────── -->

        <com.google.android.material.divider.MaterialDivider
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/text_label_ubicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/label_ubicacion_gps"
            android:textAppearance="?attr/textAppearanceTitleSmall"
            android:textColor="?attr/colorOnSurface"
            android:textStyle="bold" />

        <!-- Mapa de Google -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:strokeColor="?attr/colorOutlineVariant"
            app:strokeWidth="1dp">

            <com.google.android.gms.maps.MapView
                android:id="@+id/map_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_obtener_ubicacion"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="10dp"
            android:text="@string/btn_obtener_ubicacion"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_mylocation"
            app:iconGravity="textStart" />

        <TextView
            android:id="@+id/text_ubicacion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/sin_ubicacion"
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:gravity="center"
            android:padding="8dp" />

        <!-- ─────────────────────────────────────────────── -->
        <!-- Botones de acción                               -->
        <!-- ─────────────────────────────────────────────── -->

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_guardar"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="32dp"
            android:text="@string/btn_guardar"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_save"
            app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_compartir"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp"
            android:text="@string/btn_compartir"
            android:textAllCaps="false"
            app:cornerRadius="12dp"
            app:icon="@drawable/ic_share"
            app:iconGravity="textStart"
            app:strokeWidth="1dp" />

    </LinearLayout>

</ScrollView>
